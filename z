  sprite.setTextDatum(TL_DATUM);
}




void handleFirePopup(bool firePressed, bool fireSwitchAllowed) {

    // Button pressed and allowed
    if (firePressed && fireSwitchAllowed) {
        // Show popup immediately
        if (!firePopupActive) {
            firePopupActive = true;
            Serial.println("🔥 FIRE POPUP ON (button pressed)");
        }
        fireReleased = false; // Reset released flag while button is pressed
    } 
    else if (firePopupActive && !firePressed) {
        // Button released: start 5-second timer
        if (!fireReleased) {
            firePopupStart = millis();  // start countdown
            fireReleased = true;
            Serial.println("⏳ FIRE POPUP will stay for 5 sec");
        }

        // Check if 5 seconds passed after release
        if (millis() - firePopupStart >= FIRE_POPUP_DURATION) {
            firePopupActive = false;  // turn off popup
            fireReleased = false;     // reset
            Serial.println("🔥 FIRE POPUP OFF (5 sec after release)");
        }
    }
}

