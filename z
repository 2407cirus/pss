void sendCommand(String cmd) {

  Serial.print("CMD → ");
  Serial.println(cmd);

  e22.println(cmd);

  unsigned long t = millis();
  Serial.print("RESP ← ");

  while (millis() - t < 500) {
    if (e22.available()) {
      Serial.write(e22.read());
      t = millis();
    }
  }
  Serial.println();
}
uint8_t getAddressForGroup(uint8_t group) {
  if (group == 1) return ADDR_G1;
  if (group == 2) return ADDR_G2;
  if (group == 3) return ADDR_G3;
  return 0xFF; // invalid
}
uint8_t getSelectedGroup() {

  bool p1 = (digitalRead(PIN1) == LOW);
  bool p2 = (digitalRead(PIN2) == LOW);
  bool p3 = (digitalRead(PIN3) == LOW);

  if (p1 && p2 && p3) return 3;   // G3
  if (p1 && p2)        return 2;   // G2
  if (p1)              return 1;   // G1

  return 0; // NONE / INVALID
}

void E22_Receive() {

  static String rxBuffer = "";

  while (e22.available()) {
    char c = e22.read();

    if (c == '\n') {
      rxBuffer.trim();
      if (rxBuffer.length() == 0) {
        rxBuffer = "";
        return;
      }

      Serial.print("📥 RAW ENCRYPTED RX: ");
      Serial.println(rxBuffer);

      // ===============================
      // 🔐 FIRST — DECRYPT PACKET
      // ===============================
      String decrypted = decryptE22(rxBuffer);

      Serial.print("🔓 DECRYPTED RX: ");
      Serial.println(decrypted);

      // ===============================
      // EXPECTED FORMAT AFTER DECRYPT:
      // ADDR|TYPE|MODE
      // ===============================

      int p1 = decrypted.indexOf('|');
      int p2 = decrypted.indexOf('|', p1 + 1);

      if (p1 < 0 || p2 < 0) {
        Serial.println("❌ Invalid packet format");
        rxBuffer = "";
        return;
      }

      String addrStr = decrypted.substring(0, p1);
      String type    = decrypted.substring(p1 + 1, p2);
      String mode    = decrypted.substring(p2 + 1);

      uint8_t rxAddr = strtol(addrStr.c_str(), NULL, 16);

      Serial.print("✅ Packet accepted | ADDR: ");
      Serial.print(rxAddr, HEX);
      Serial.print(" | TYPE: ");
      Serial.print(type);
      Serial.print(" | MODE: ");
      Serial.println(mode);

      // ===============================
      // 🔥 FIRE LOGIC
      // ===============================
      if (type == "FIRE") {
        if (mode == "SEQ" || mode == "CONC") {
          fireMode = mode;
        }

        fireNow = true;
        logStateChange("FIRE_FROM_LORA");

        Serial.print("🔥 FIRE RECEIVED | MODE: ");
        Serial.println(fireMode);

        if (sysModeText != "SA") {
          sendFireCommandToLMU();
        } else {
          Serial.println("🚫 SYSTEM MODE = SA → NOT sending to LMU");
        }
      }

      else if (type == "ACK") {
        ack_time = "OK";
      }

      rxBuffer = "";
    }

    else {
      rxBuffer += c;
    }
  }
}



void E22_SendFire() {

  uint8_t group  = getAddressForGroup(getSelectedGroup());  if (group == 0) {
    Serial.println("❌ FIRE TX blocked (no group)");
    return;
  }

  uint8_t addr = getAddressForGroup(group);

  String payload =
    String(addr, HEX) + "|FIRE|" + fireMode;

  String enc = encryptE22(payload);

  Serial.print("🔥📤 ENCRYPTED FIRE: ");
  Serial.println(enc);

  e22.println(enc);
}
