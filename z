void saveStateLogToEEPROM() {

  static unsigned long lastSave = 0;
  if (millis() - lastSave < 60000) return;
  lastSave = millis();

  int addr = 0;
  uint16_t count = min(300, stateLogWrapped ? STATE_LOG_MAX : stateLogIndex);

  EEPROM.put(addr, count);
  addr += sizeof(uint16_t);

  for (int i = 0; i < count; i++) {
    int idx = (stateLogIndex + STATE_LOG_MAX - count + i) % STATE_LOG_MAX;
    EEPROM.put(addr, stateLog[idx]);
    addr += sizeof(GNSS_State_Log);
  }

  EEPROM.commit();
}
void convertToIST(int &hour, int &minute, int &second) {
  minute += 30;
  hour += 5;

  if (minute >= 60) {
    minute -= 60;
    hour += 1;
  }

  if (hour >= 24) {
    hour -= 24;
  }
}

