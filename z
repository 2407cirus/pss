// BLE BACKGROUND TASK (Core 0)
// ===============================
TaskHandle_t bleTaskHandle;

void BLE_Task(void * parameter) {


  unsigned long lastReconnectLM1 = 0;
  unsigned long lastReconnectLM2 = 0;
  unsigned long lastSendLM1 = 0;
  unsigned long lastSendLM2 = 0;

  for (;;) {
    // LMU1 Watchdog
    if (connectedLM1 && millis() - lastAckTimeLM1 > ACK_TIMEOUT) {
      connectedLM1 = false;
      lm1Status = false;
      ackReceivedLM1 = false;
    }

    // LMU2 Watchdog
    if (connectedLM2 && millis() - lastAckTimeLM2 > ACK_TIMEOUT) {
      connectedLM2 = false;
      lm2Status = false;
      ackReceivedLM2 = false;
    }

    // Auto Reconnect LMU1
    if (!connectedLM1 && millis() - lastReconnectLM1 > 3000) {
      lastReconnectLM1 = millis();
      connectServerLM1();
    }

    // Auto Reconnect LMU2
    if (!connectedLM2 && millis() - lastReconnectLM2 > 3000) {
      lastReconnectLM2 = millis();
      connectServerLM2();
    }

    // LMU1 Heartbeat
    if (connectedLM1 && ackReceivedLM1 && millis() - lastSendLM1 > 2000) {
      lastSendLM1 = millis();
      ackReceivedLM1 = false;

      const char* plainText = "LM1_STATUS_OK";
      char encrypted[128];

      aes.encrypt64(
        (byte*)plainText,
        strlen(plainText),
        encrypted,
        aes_key,
        128,
        aes_iv
      );

      if (pRxLM1)
pRxLM1->writeValue(
  (uint8_t*)plainText,
  strlen(plainText)
);
    }

    // LMU2 Heartbeat
    if (connectedLM2 && ackReceivedLM2 && millis() - lastSendLM2 > 2000) {
      lastSendLM2 = millis();
      ackReceivedLM2 = false;

      const char* plainText = "LM2_STATUS_OK";
      char encrypted[128];

      aes.encrypt64(
        (byte*)plainText,
        strlen(plainText),
        encrypted,
        aes_key,
        128,
        aes_iv
      );

      if (pRxLM2)
pRxLM2->writeValue(
  (uint8_t*)plainText,
  strlen(plainText)
);
    }

    vTaskDelay(10 / portTICK_PERIOD_MS);
  }
