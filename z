void sendFireCommandToLMU() {

  // ===============================
  // 🔧 TEST / OPS MODE DETECTION
  // ===============================
  String opsMode = (digitalRead(TEST_OPS_PIN) == HIGH) ? "TEST" : "OPS";

  // ===============================
  // 🔥 FINAL FIRE COMMAND
  // ===============================
  String fireCmd = "FIRE+" + fireMode + "+" + opsMode;

  Serial.println("================================");
  Serial.println("🔥 SEND FIRE TO LMU (BLE)");
  Serial.print("➡️ Command: ");
  Serial.println(fireCmd);

  char encrypted[128];

  // ---------- LMU1 ----------
  if (connectedLM1 && pRxLM1) {

    aes.encrypt64(
      (byte*)fireCmd.c_str(),
      fireCmd.length(),
      encrypted,
      aes_key,
      128,
      aes_iv
    );

pRxLM1->writeValue(
  (uint8_t*)fireCmd.c_str(),
  fireCmd.length()
);

    Serial.println("✅ Sent to LMU1");
  }
  else {
    Serial.println("❌ LMU1 NOT CONNECTED");
  }

  // ---------- LMU2 ----------
  if (connectedLM2 && pRxLM2) {

    aes.encrypt64(
      (byte*)fireCmd.c_str(),
      fireCmd.length(),
      encrypted,
      aes_key,
      128,
      aes_iv
    );

pRxLM2->writeValue(
  (uint8_t*)fireCmd.c_str(),
  fireCmd.length()
);

    Serial.println("✅ Sent to LMU2");
  }
  else {
    Serial.println("❌ LMU2 NOT CONNECTED");
  }

  Serial.println("================================");
}



void drawAutoSOSWarning() {

  const unsigned long SOLID_TIME = 2000;   // 2 sec solid
  const unsigned long BLINK_ON   = 1000;   // 1 sec ON
  const unsigned long BLINK_OFF  = 1000;   // 1 sec OFF

  unsigned long now = millis();

  // ===============================
  // 🧠 BLINK STATE MACHINE
  // ===============================
  if (now - autoWarningStartTime < SOLID_TIME) {
    autoWarningBlinkState = true;   // solid phase
  }
  else {
    if (autoWarningBlinkState &&
        now - autoWarningLastBlink >= BLINK_ON) {

      autoWarningBlinkState = false;
      autoWarningLastBlink = now;
    }
    else if (!autoWarningBlinkState &&
             now - autoWarningLastBlink >= BLINK_OFF) {

      autoWarningBlinkState = true;
      autoWarningLastBlink = now;
    }
  }

  // OFF phase → kuch draw nahi
  if (!autoWarningBlinkState) return;

  // ===============================
  // 📦 DRAW WARNING BOX
  // ===============================
  int boxW = 420;
  int boxH = 90;
  int boxX = (536 - boxW) / 2;
  int boxY = (240 - boxH) / 2;

