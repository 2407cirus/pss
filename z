// Battery icon
void drawBatteryIcon(int x, int y, int w, int h, float voltage)
{
  float batteryPercent = map(voltage * 100, 330, 420, 0, 100);
  batteryPercent = constrain(batteryPercent, 0, 100);

  // Outer Border
  sprite.drawRoundRect(x, y, w, h, 4, TFT_WHITE);

  // Battery Tip
  sprite.fillRoundRect(x + w + 2, y + h / 3, 5, h / 3, 2, TFT_WHITE);

  // Decide Color
  uint16_t col;
  if (batteryPercent < 20) col = TFT_RED;
  else if (batteryPercent < 50) col = TFT_YELLOW;
  else col = TFT_GREEN;

  // Segment Settings
  int segments = 4;
  int gap = 3;
  int segW = (w - 8 - (gap * (segments - 1))) / segments;
  int segH = h - 8;

  int activeSegments = 0;
  if (batteryPercent > 80) activeSegments = 4;
  else if (batteryPercent > 60) activeSegments = 3;
  else if (batteryPercent > 40) activeSegments = 2;
  else if (batteryPercent > 15) activeSegments = 1;

  // Draw Segments
  for (int i = 0; i < segments; i++) {
    int sx = x + 5 + i * (segW + gap);
    int sy = y + 5;

    // Empty Segment Border
    sprite.drawRect(sx, sy, segW, segH, TFT_DARKGREY);

    // Filled Segment
    if (i < activeSegments) {
      sprite.fillRect(sx + 1, sy + 1, segW - 2, segH - 2, col);
    }
  }
// Percentage Text at bottom-left
// sprite.setTextSize(2);
sprite.setTextColor(TFT_GREEN); // now the text is green
sprite.setTextDatum(BL_DATUM);
// sprite.drawString(String((int)batteryPercent) + "%", x, y + h + 2);

  // Percentage Text (optional)
     drawCenteredText(String((int)batteryPercent) + "%", x + w/4 , y + h + 27, 4);
