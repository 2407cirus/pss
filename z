String encryptLine(String plain)
{
  char encrypted[256];

  aes.encrypt64(
    (byte*)plain.c_str(),
    plain.length(),
    encrypted,
    aes_key,
    128,
    aes_iv
  );

  return String(encrypted);
}
// Convert bytes → HEX string
String bytesToHex(byte *buf, int len){
  String out = "";
  char temp[3];
  for(int i=0;i<len;i++){
    sprintf(temp,"%02X",buf[i]);
    out += temp;
  }
  return out;
}

// Convert HEX string → bytes
int hexToBytes(String hex, byte *buf){
  int len = hex.length();
  int finalLen = len / 2;
  for(int i=0;i<finalLen;i++){
    buf[i] = (uint8_t) strtol(hex.substring(2*i,2*i+2).c_str(),NULL,16);
  }
  return finalLen;
}



// Encrypt Plain → HEX Cipher
String encryptE22(String plain){
  byte encrypted[256];

  aes.encrypt64(
    (byte*)plain.c_str(),
    plain.length(),
    (char*)encrypted,
    aes_key,
    128,
    aes_iv
  );

  return bytesToHex(encrypted, plain.length());
}



// Decrypt HEX Cipher → Plain
String decryptE22(String hexCipher) {

  byte cipher[256];
  int len = hexToBytes(hexCipher, cipher);

  byte decrypted[256];

  byte iv[16];
  memcpy(iv, aes_iv, 16);     // reset IV for every decrypt

  aes.decrypt64(
    (char*)cipher,            // input must be char*
    len,
    decrypted,                // output must be byte*
    aes_key,
    128,
    iv
  );

  decrypted[len] = '\0';
  return String((char*)decrypted);
}

