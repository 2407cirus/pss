  sprite.drawArc(cx, cy, R1, R1 - thick,
                 A1, A2,
                 (strength >= 4 ? colActive : colInactive),
                 bg);

  // Arc 2 (middle)
  sprite.drawArc(cx, cy, R2, R2 - thick,
                 A1, A2,
                 (strength >= 3 ? colActive : colInactive),
                 bg);

  // Arc 3 (inner)
  sprite.drawArc(cx, cy, R3, R3 - thick,
                 A1, A2,
                 (strength >= 2 ? colActive : colInactive),
                 bg);

  // Label under icon
  drawCenteredText(label, cx, cy + 48, 4, colActive);
}



