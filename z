uint32_t getCurrentTimeSeconds() {
  return gpsData.hour * 3600UL +
         gpsData.minute * 60UL +
         gpsData.second;
}
void logStateChange(const char* stateName) {

  GNSS_State_Log &e = stateLog[stateLogIndex];

  e.timestamp = getCurrentTimeSeconds();

  if (gpsData.hasFix) {
    e.latitude  = gpsData.latitude;
    e.longitude = gpsData.longitude;
  } else {
    e.latitude  = 0.0;
    e.longitude = 0.0;
  }

  strncpy(e.state, stateName, STATE_NAME_LEN - 1);
  e.state[STATE_NAME_LEN - 1] = '\0';

  stateLogIndex++;
  if (stateLogIndex >= STATE_LOG_MAX) {
    stateLogIndex = 0;
    stateLogWrapped = true;
  }

  Serial.print("📝 STATE LOGGED: ");
  Serial.println(stateName);

  if (!SD_MMC.begin("/sdcard", true)) {
    Serial.println("❌ SD not ready");
    return;
  }

  File f = SD_MMC.open("/state_log.csv", FILE_APPEND);
  if (!f) {
    Serial.println("❌ Failed to open log file");
    return;
  }

String line =
  String(e.timestamp) + "," +
  String(e.latitude, 6) + "," +
  String(e.longitude, 6) + "," +
  String(e.state);

// Encrypt and save
String enc = encryptLine(line);
f.println(enc);

  f.close();
  Serial.println("📁 Saved to SD");
}
