// ===============================
if (firePopupActive) {

  if (millis() - fireLastBlink >= FIRE_BLINK_INTERVAL) {
    fireBlinkState = !fireBlinkState;
    fireLastBlink = millis();
  }

  if (millis() - firePopupStart >= FIRE_POPUP_SHOW_MS) {
    firePopupActive = false;
    fireBlinkState  = false;
  }
}

