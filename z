void receiveData() {
  while (e22.available()) {
    char c = e22.read();

    // Filter out non-printable characters
    if (isPrintable(c) || c == '\n' || c == '\r') {
      rxData += c;
    }
  }

  // If a complete message is received (newline-terminated)
  if (rxData.length() > 0 && (rxData.endsWith("\n") || rxData.endsWith("\r"))) {
    // Remove any extra newline/carriage return
    rxData.trim();

    if (rxData.length() > 0) {
      Serial.print("[RX] Received: ");
      Serial.println(rxData);

      // Visual feedback

    }

    rxData = ""; // Clear buffer
  }
}


