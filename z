  sprite.setTextDatum(MC_DATUM);
  sprite.setTextFont(4);
  sprite.setTextColor(TFT_BLACK, TFT_ORANGE);

  sprite.drawString("AUTO SOS IN 15 MINUTES", 268, boxY + 30);
