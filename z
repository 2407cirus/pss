bool connectServerLM1() {
  Serial.println("🔄 Connecting to LMU1 ...");

  pClientLM1 = BLEDevice::createClient();
  pClientLM1->setClientCallbacks(new ClientCB_LM1());

  if (!pClientLM1->connect(serverAddressLM1)) {
    Serial.println("❌ LMU1 Connect Failed");
    return false;
  }

  BLERemoteService* s = pClientLM1->getService(SERVICE_UUID);
  if (!s) return false;

  pRxLM1 = s->getCharacteristic(RX_UUID);
  pTxLM1 = s->getCharacteristic(TX_UUID);

  if (!pRxLM1 || !pTxLM1) return false;

  pTxLM1->registerForNotify(notifyCB_LM1);

  connectedLM1 = true;
  ackReceivedLM1 = false;
  lastAckTimeLM1 = millis();
  lm1Status = false;

  Serial.println("✅ LMU1 Connected, Waiting for ACK...");

  // Send initial ping
  const char* ping = "REQ_LM1";
  pRxLM1->writeValue((uint8_t*)ping, strlen(ping));

  return true;
}

