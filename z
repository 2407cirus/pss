float readBatteryVoltage() {
  int raw = analogRead(BAT_ADC_PIN);   // 0..4095

  // 🔒 Floating pin filter:
  // agar bohot chhota raw hai, assume no battery / no signal
  if (raw < 50) {   // threshold adjust kar sakte ho
    return 0.0;     // No battery / no reading
  }

  float vAdc = (raw / 4095.0f) * 3.3f; // ADC pin voltage (0–3.3V)
  float vBat = vAdc * 2.0f;            // divider ×2

  return vBat;
}

int getBatteryPercent(float vBat) {
  if (vBat <= 0.1f) return 0;   // no battery detected
  if (vBat >= 4.10f) return 100;
  if (vBat <= 3.35f) return 0;

  float percent = (vBat - 3.35f) * 100.0 / (4.10f - 3.35f);
  return constrain((int)percent, 0, 100);
}



