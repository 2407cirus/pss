    fireLastBlink   = millis();
    fireBlinkState  = true;

    fireSentOnce = true;   // 🔒 ONE-SHOT
  }
}
else {
  // 🔁 Reset on release or mode change
  firePressStart = 0;
  fireSentOnce   = false;
}

// ===============================
