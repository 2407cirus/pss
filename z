void draw3x3Table_MiddleBig(int startX, int startY,
                            int colW_small, int colW_big,
                            int rowH_small, int rowH_big,
                            uint16_t color)
{
    int colW[3] = { colW_small, colW_big, colW_small };
    int rowH[3] = { rowH_small, rowH_big, rowH_small };

    uint16_t borderColor  = color;
    uint16_t shadowColor  = TFT_BLACK;

    int y = startY;

    for (int r = 0; r < 3; r++)
    {
        int x = startX;

        for (int c = 0; c < 3; c++)
        {
            int w = colW[c];
            int h = rowH[r];

            // --- CLEAN DARK BACKGROUND ---
            sprite.fillRect(x + 1, y + 1, w - 2, h - 2, shadowColor);

            // --- BOLD OUTER BORDER ---
            sprite.drawRect(x, y, w, h, borderColor);
            sprite.drawRect(x + 1, y + 1, w - 2, h - 2, borderColor);

            // ===============================
            // ✅ DRAW VALUES IN MIDDLE COLUMN
            // ===============================
            if (c == 1) {   // middle column only
                sprite.setTextDatum(MC_DATUM);
                sprite.setTextFont(4);
                sprite.setTextColor(TFT_GREEN, TFT_BLACK);

                String valueText = "";

                if (r == 0) valueText = HT_value;    // Row 1 → HT VALUE
                if (r == 1) valueText = COG_value;   // Row 2 → COG VALUE
                if (r == 2) valueText = SOG_value;   // Row 3 → SOG / DEG VALUE

                sprite.drawString(valueText,
                                  x + w / 2,
                                  y + h / 2);
            }

            x += w;
        }

        y += rowH[r];
    }

    // ---- OUTER FRAME (double line) ----
    int totalW = colW_small + colW_big + colW_small;
    int totalH = rowH_small + rowH_big + rowH_small;

    sprite.drawRect(startX - 2, startY - 2, totalW + 4, totalH + 4, borderColor);
    sprite.drawRect(startX - 3, startY - 3, totalW + 6, totalH + 6, borderColor);

    sprite.setTextDatum(TL_DATUM);  // reset
}


static bool ackProcessedLM1 = false;   // 🔒 GLOBAL / STATIC LOCK


static void notifyCB_LM1(BLERemoteCharacteristic*, uint8_t* d, size_t len, bool) {

  String r = "";
  for (int i = 0; i < (int)len; i++) r += (char)d[i];

  Serial.print("📥 BLE LM1 RX: ");
  Serial.println(r);

  lastAckTimeLM1 = millis();
  ackReceivedLM1 = true;
  connectedLM1   = true;
  lm1Status      = true;

  // ===============================
  // ✅ RUN ONLY ONCE (FIRST ACK)
  // ===============================
  if (!ackProcessedLM1 && (r == "ACK1" || r == "ACK")) {

    ackProcessedLM1 = true;   // 🔒 LOCK FIRST (important)

    Serial.println("✅ LMU1 ACK RECEIVED (FIRST TIME)");

    char encrypted[128];

    aes.encrypt64(
      (byte*)ACK_BACK_LM1,
      strlen(ACK_BACK_LM1),
      encrypted,
      aes_key,
      128,
      aes_iv
    );

    if (pRxLM1) {
      pRxLM1->writeValue(
        (uint8_t*)ACK_BACK_LM1,
        strlen(ACK_BACK_LM1)
      );
      Serial.println("📤 ACK_BACK_LM1 SENT (ONCE)");
    }
  }
}
void E22_RxAliveCheck() {

  static unsigned long lastPrint = 0;

  // Every 1 second, show RX alive status
  if (millis() - lastPrint >= 1000) {
    lastPrint = millis();
    Serial.println("👂 E22 RX MODE ACTIVE");
  }

  // If actual data arrives, print it
  while (e22.available()) {
    char c = e22.read();
    Serial.print("📥 E22 RX BYTE: ");
    Serial.println(c);
  }
}

